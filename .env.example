CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

AUTH_JWT_SECRET=replace-with-a-long-random-secret

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional free-month coupon:
# - Set SUBSCRIPTION_COUPON_CODE to the raw coupon value, or
# - Set SUBSCRIPTION_COUPON_CODE_HASH to the AUTH_JWT_SECRET-backed HMAC of that value.
#   If both are present, SUBSCRIPTION_COUPON_CODE_HASH is used.
SUBSCRIPTION_COUPON_CODE=
SUBSCRIPTION_COUPON_CODE_HASH=
# Required when coupon redemption is enabled. ISO timestamp or unix timestamp.
SUBSCRIPTION_COUPON_EXPIRES_AT=
# Required when coupon redemption is enabled. Positive integer.
SUBSCRIPTION_COUPON_MAX_REDEMPTIONS=
# Defaults to true. When true, only inactive users can redeem the coupon.
SUBSCRIPTION_COUPON_ONLY_FOR_INACTIVE=true

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
