CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud
# Development-only fallback for local runs. Keep production server calls on CONVEX_URL.
NEXT_PUBLIC_CONVEX_URL=https://YOUR_DEPLOYMENT.convex.cloud

AUTH_JWT_SECRET=replace-with-a-long-random-secret
# Optional:
# AUTH_SESSION_TTL_DAYS=7
# AUTH_COOKIE_NAME=linkstore_session

# Google OAuth (required for authentication)
# Authorize this callback in Google Cloud Console:
# http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional comma-separated allowlist for trusted browser origins that can call mutating APIs.
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Razorpay billing (required for subscriptions)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Legacy env names still supported by code:
# RAZORPAY_KEY=
# RAZORPAY_SECRET=

# 32+ bytes secret for encrypting/hashing payment identifiers at rest.
# Example (hex): openssl rand -hex 32
PAYMENTS_DATA_KEY=

# Amazon Product Advertising API (optional, recommended for Amazon links)
# AMAZON_PAAPI_ACCESS_KEY=
# AMAZON_PAAPI_SECRET_KEY=
# AMAZON_PAAPI_PARTNER_TAG=yourtag-21
# AMAZON_PAAPI_HOST=webservices.amazon.in
# AMAZON_PAAPI_REGION=eu-west-1

# Optional (required only for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional support contact shown on /contact
# SUPPORT_EMAIL=support@yourdomain.com
